# Fluow Control Center - Environment Variables

# App
APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# Database (PostgreSQL / Supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fluow_control
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example

# Gemini AI
GEMINI_API_KEY=MY_GEMINI_API_KEY

# JWT Auth
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# Docker Agent
FLUOW_AGENT_URL=http://fluow-agent:3001
FLUOW_AGENT_API_KEY=fluow-agent-secret-key-change-in-production

# Internal API Key (for product-to-control-center communication)
INTERNAL_API_KEY=fluow-internal-secret-key-change-in-production

# Portainer (optional)
PORTAINER_URL=http://localhost:9001
PORTAINER_API_KEY=
