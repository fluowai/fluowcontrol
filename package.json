{
  "name": "fluow-control-center",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx server/seed.ts",
    "db:studio": "prisma studio",
    "worker:metrics": "tsx server/workers/metrics.ts",
    "worker:alerts": "tsx server/workers/alerts.ts",
    "agent": "tsx server/agent/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@prisma/client": "^6.6.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.50.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.546.0",
    "minio": "^8.0.5",
    "morgan": "^1.10.0",
    "motion": "^12.23.24",
    "pg": "^8.14.1",
    "pino": "^10.3.1",
    "rate-limit-redis": "^5.0.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "socket.io": "^4.8.1",
    "ssh2": "^1.17.0",
    "uuid": "^11.1.0",
    "vite": "^6.2.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.12",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.6.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
